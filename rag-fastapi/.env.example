# MongoDB 连接地址
MONGODB_URI=mongodb://localhost:27017/rag

# 登录密码加密密钥
PASSWORD_KEY=your_password_key

# JWT 签名密钥
JWT_SECRET=your_jwt_secret

# Milvus 向量数据库地址
MILVUS_ADDRESS=localhost:19530

# 通义千问 API Key（DashScope）
TONGYI_AKI_KEY=your_dashscope_api_key

# Redis 地址
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
